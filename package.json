{
  "name": "famtastic",
  "version": "0.0.1",
  "description": "Famtastic — Supabase migration-first project",
  "scripts": {
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:push:dry-run": "supabase db push --dry-run",
    "db:diff": "supabase db diff",
    "db:link": "supabase link --project-ref $SUPABASE_PROJECT_REF",
    "db:pull": "supabase db pull",
    "types:generate": "supabase gen types typescript --local > src/lib/database.types.ts",
    "types:generate:remote": "supabase gen types typescript --project-id $SUPABASE_PROJECT_REF > src/lib/database.types.ts",
    "db:lint": "supabase db lint",
    "db:inspect": "supabase inspect db bloat",
    "db:seed": "supabase db reset"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "@types/node": "^26.1.0",
    "dotenv-cli": "^7.4.2",
    "typescript": "^6.0.3"
  }
}
