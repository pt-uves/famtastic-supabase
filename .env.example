# ==============================================================================
# Famtastic - Supabase Environment Variables
# Copy this file to .env and fill in the values for your environment.
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# Supabase Remote Project Configuration
# ──────────────────────────────────────────────────────────────────────────────
# The project reference identifier for your remote Supabase project.
# Used by commands like: npm run db:link or npm run types:generate:remote
SUPABASE_PROJECT_REF=your-supabase-project-ref

# ──────────────────────────────────────────────────────────────────────────────
# Supabase API & Edge Functions Credentials
# ──────────────────────────────────────────────────────────────────────────────
# Local values are populated automatically on `npm run db:start`.
# Replace these with production keys when configuring remote deployments.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-local-or-remote-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-or-remote-service-role-key

# ──────────────────────────────────────────────────────────────────────────────
# Push Notifications — send-push edge function (FCM HTTP v1)
# ──────────────────────────────────────────────────────────────────────────────
# send-push is SERVER-INVOKED ONLY: the DB dispatch trigger POSTs to it via
# pg_net when a notification is created (see migration 0010; retry is built into
# send-push). Authenticated with the shared secret below, NEVER the service-role
# key. It must equal the Vault 'push_webhook_secret'
# (local: supabase/seeds/vault_secrets.local.sql; remote: vault.create_secret).
PUSH_WEBHOOK_SECRET=local-dev-webhook-secret-change-me

# Firebase Cloud Messaging service account (console.firebase.google.com →
# Project settings → Service accounts → Generate new private key). Delivery via
# the FCM HTTP v1 API; the legacy server-key API is not used.
FCM_PROJECT_ID=your-firebase-project-id
FCM_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Keep the PEM on one line with literal \n between lines (fcm.ts unescapes them).
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ──────────────────────────────────────────────────────────────────────────────
# External Authentication Providers
# ──────────────────────────────────────────────────────────────────────────────
# Google OAuth 2.0 Credentials (console.cloud.google.com)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your-google-client-secret

# Apple Sign-In Credentials (developer.apple.com)
SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=your-apple-client-id
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=your-apple-client-secret

# ──────────────────────────────────────────────────────────────────────────────
# Third Party Integrations
# ──────────────────────────────────────────────────────────────────────────────
# OpenAI API Key (used for local Studio AI and assistant features)
OPENAI_API_KEY=your-openai-api-key

# Twilio Auth Token (used if Twilio SMS authentication is enabled)
SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=your-twilio-auth-token

# ──────────────────────────────────────────────────────────────────────────────
# SMTP — the SINGLE email config for the whole backend.
# Drives BOTH (a) Supabase Auth emails via config.toml → [auth.email.smtp], and
# (b) transactional edge-function emails via functions/_shared/email.ts.
# Switching providers (Resend → Amazon SES → anything) is JUST these values —
# no code changes anywhere.
#
# Resend:      host smtp.resend.com · port 465 · user "resend" · pass = API key
#              From must be a domain verified in Resend (onboarding@resend.dev for local).
# Amazon SES:  host email-smtp.<region>.amazonaws.com · port 587 · user = IAM SMTP username
#              pass = SES SMTP password (derived from IAM creds) · From = verified SES sender.
# ──────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_your_resend_api_key
SMTP_ADMIN_EMAIL=onboarding@resend.dev
SMTP_SENDER_NAME=Famtastic

