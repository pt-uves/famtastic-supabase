# Vault secrets, upserted by `npm run db:secrets` (scripts/set-vault-secrets.sh).
# Copy to vault-secrets.env (gitignored) and fill in real values.
#
# Format: NAME=value  (one per line; blank lines and #-comments ignored).
# Add a new secret by adding a new line here — no code changes needed.
#
# LOCAL: run `npm run db:secrets` after each `db reset` (reset wipes the DB,
#        vault included). The values below are the local-dev defaults.
# PROD:  set DB_URL to the project connection string first; use real values
#        (edge_base_url=https://<ref>.supabase.co, a random push_webhook_secret).

# Base URL the DB uses to reach the send-push edge function.
# Local: the db container reaches the functions runtime via host.docker.internal.
edge_base_url=http://host.docker.internal:54321

# Shared webhook secret; MUST match the edge function's PUSH_WEBHOOK_SECRET env
# var. Prod: generate a fresh one with `openssl rand -hex 32`.
push_webhook_secret=local-dev-webhook-secret-change-me
